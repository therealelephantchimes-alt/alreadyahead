# =============================================================================
# alreadyahead.net — Environment Variables
# Copy this file to .env.local for local development.
# All of these must be set in Vercel Project Settings for production.
# =============================================================================

# ---- Public site URL (used for redirects, emails, Stripe success/cancel URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase (https://supabase.com) -----------------------------------------
# Create a project, then Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ---- Stripe (https://dashboard.stripe.com) -----------------------------------
# Use test keys (sk_test_, pk_test_) in development, live keys in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Two recurring prices you created in Stripe (one per tier).
STRIPE_PRICE_TIER_1=price_...
STRIPE_PRICE_TIER_2=price_...

# ---- Resend (https://resend.com) ---------------------------------------------
# Verify the alreadyahead.net domain in Resend, then create an API key.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Cole Ashford <hello@alreadyahead.net>"

# ---- PostHog (https://posthog.com) -------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
